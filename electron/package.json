{
  "name": "@roko/electron",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop shell for RokoCluster.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env ELECTRON_DEV=1 electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.roko.cluster",
    "productName": "RokoCluster",
    "files": ["main.js", "preload.js"],
    "extraResources": [
      { "from": "../backend/dist", "to": "backend/dist" },
      { "from": "../backend/node_modules", "to": "backend/node_modules" },
      { "from": "../frontend/dist", "to": "frontend" }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
