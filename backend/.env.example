# Backend configuration (all optional — sensible defaults shown).
PORT=4000

# How the backend obtains its initial cluster connection:
#   upload     -> start with no connection; upload a kubeconfig from the UI (default)
#   default    -> use local kubeconfig (KUBECONFIG / ~/.kube/config) on startup
#   in-cluster -> use the mounted service-account token (when deployed in a Pod)
# A kubeconfig can always be uploaded at runtime to switch clusters.
KUBE_AUTH=upload

# Comma-separated CORS allow-list for the frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Serve a built frontend from this directory (production single-container mode).
# STATIC_DIR=/app/frontend

# Tuning.
CACHE_TTL_MS=5000
REBUILD_DEBOUNCE_MS=300
